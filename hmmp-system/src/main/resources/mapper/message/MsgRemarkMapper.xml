<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.message.MsgRemarkMapper">

    <resultMap type="MsgRemark" id="MsgRemarkResult">
        <id     property="remarkId"      column="remark_id"       />
        <result property="articleId"     column="article_id"      />
        <result property="userId"        column="user_id"         />
        <result property="userName"      column="user_name"       />
        <result property="content"       column="content"         />
        <result property="replyContent"  column="reply_content"   />
        <result property="replyTime"     column="reply_time"      />
        <result property="replyBy"       column="reply_by"        />
        <result property="status"        column="status"          />
        <result property="createTime"    column="create_time"     />
    </resultMap>

    <sql id="selectRemarkVo">
        select remark_id, article_id, user_id, user_name, content, reply_content, reply_time, reply_by, status, create_time
        from msg_remark
    </sql>

    <select id="selectRemarkList" parameterType="MsgRemark" resultMap="MsgRemarkResult">
        <include refid="selectRemarkVo"/>
        <where>
            <if test="articleId != null">AND article_id = #{articleId}</if>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="userName != null and userName != ''">AND user_name like concat('%', #{userName}, '%')</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectRemarkById" parameterType="Long" resultMap="MsgRemarkResult">
        <include refid="selectRemarkVo"/>
        where remark_id = #{remarkId}
    </select>

    <insert id="insertRemark" parameterType="MsgRemark" useGeneratedKeys="true" keyProperty="remarkId">
        insert into msg_remark(
            <if test="articleId != null">article_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="content != null">content,</if>
            <if test="replyContent != null">reply_content,</if>
            <if test="replyTime != null">reply_time,</if>
            <if test="replyBy != null">reply_by,</if>
            <if test="status != null">status,</if>
            create_time
        )values(
            <if test="articleId != null">#{articleId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="content != null">#{content},</if>
            <if test="replyContent != null">#{replyContent},</if>
            <if test="replyTime != null">#{replyTime},</if>
            <if test="replyBy != null">#{replyBy},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        )
    </insert>

    <update id="updateRemark" parameterType="MsgRemark">
        update msg_remark
        <set>
            <if test="articleId != null">article_id = #{articleId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="content != null">content = #{content},</if>
            <if test="replyContent != null">reply_content = #{replyContent},</if>
            <if test="replyTime != null">reply_time = #{replyTime},</if>
            <if test="replyBy != null">reply_by = #{replyBy},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where remark_id = #{remarkId}
    </update>

    <delete id="deleteRemarkById" parameterType="Long">
        delete from msg_remark where remark_id = #{remarkId}
    </delete>

    <delete id="deleteRemarkByIds" parameterType="Long">
        delete from msg_remark where remark_id in
        <foreach collection="array" item="remarkId" open="(" separator="," close=")">
            #{remarkId}
        </foreach>
    </delete>

</mapper>