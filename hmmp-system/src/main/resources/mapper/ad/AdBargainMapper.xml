<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdBargainMapper">
    
    <resultMap type="AdBargain" id="AdBargainResult">
        <id     property="bargainId"      column="bargain_id"       />
        <result property="bargainNo"      column="bargain_no"       />
        <result property="customerId"     column="customer_id"      />
        <result property="customerName"   column="customer_name"    />
        <result property="bargainName"    column="bargain_name"     />
        <result property="totalAmount"    column="total_amount"     />
        <result property="signDate"       column="sign_date"        />
        <result property="startDate"      column="start_date"       />
        <result property="endDate"        column="end_date"         />
        <result property="bargainContent" column="bargain_content"  />
        <result property="bargainFile"    column="bargain_file"     />
        <result property="applyStatus"    column="apply_status"     />
        <result property="auditTime"      column="audit_time"       />
        <result property="auditBy"        column="audit_by"         />
        <result property="auditOpinion"   column="audit_opinion"    />
        <result property="printStatus"    column="print_status"     />
        <result property="printTime"      column="print_time"       />
        <result property="status"         column="status"           />
        <result property="createBy"       column="create_by"        />
        <result property="createTime"     column="create_time"      />
        <result property="updateBy"       column="update_by"        />
        <result property="updateTime"     column="update_time"      />
    </resultMap>
    
    <sql id="selectBargainVo">
        select bargain_id, bargain_no, customer_id, customer_name, bargain_name, total_amount, sign_date, start_date, end_date, bargain_content, bargain_file, apply_status, audit_time, audit_by, audit_opinion, print_status, print_time, status, create_by, create_time, update_by, update_time 
        from ad_bargain
    </sql>
    
    <select id="selectBargainList" parameterType="AdBargain" resultMap="AdBargainResult">
        <include refid="selectBargainVo"/>
        <where>
            <if test="bargainNo != null and bargainNo != ''">
                AND bargain_no like concat('%', #{bargainNo}, '%')
            </if>
            <if test="customerId != null">
                AND customer_id = #{customerId}
            </if>
            <if test="bargainName != null and bargainName != ''">
                AND bargain_name like concat('%', #{bargainName}, '%')
            </if>
            <if test="applyStatus != null and applyStatus != ''">
                AND apply_status = #{applyStatus}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectBargainById" parameterType="Long" resultMap="AdBargainResult">
        <include refid="selectBargainVo"/>
        where bargain_id = #{bargainId}
    </select>
    
    <insert id="insertBargain" parameterType="AdBargain" useGeneratedKeys="true" keyProperty="bargainId">
        insert into ad_bargain (
            <if test="bargainNo != null and bargainNo != ''">bargain_no,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="customerName != null">customer_name,</if>
            <if test="bargainName != null">bargain_name,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="signDate != null">sign_date,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="bargainContent != null">bargain_content,</if>
            <if test="bargainFile != null">bargain_file,</if>
            <if test="applyStatus != null and applyStatus != ''">apply_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="bargainNo != null and bargainNo != ''">#{bargainNo},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="customerName != null">#{customerName},</if>
            <if test="bargainName != null">#{bargainName},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="signDate != null">#{signDate},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="bargainContent != null">#{bargainContent},</if>
            <if test="bargainFile != null">#{bargainFile},</if>
            <if test="applyStatus != null and applyStatus != ''">#{applyStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateBargain" parameterType="AdBargain">
        update ad_bargain 
        <set>
            <if test="bargainNo != null and bargainNo != ''">bargain_no = #{bargainNo},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="customerName != null">customer_name = #{customerName},</if>
            <if test="bargainName != null">bargain_name = #{bargainName},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="signDate != null">sign_date = #{signDate},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="bargainContent != null">bargain_content = #{bargainContent},</if>
            <if test="bargainFile != null">bargain_file = #{bargainFile},</if>
            <if test="applyStatus != null and applyStatus != ''">apply_status = #{applyStatus},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditOpinion != null">audit_opinion = #{auditOpinion},</if>
            <if test="printStatus != null and printStatus != ''">print_status = #{printStatus},</if>
            <if test="printTime != null">print_time = #{printTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where bargain_id = #{bargainId}
    </update>
    
    <delete id="deleteBargainById" parameterType="Long">
        delete from ad_bargain where bargain_id = #{bargainId}
    </delete>
    
    <delete id="deleteBargainByIds" parameterType="Long">
        delete from ad_bargain where bargain_id in 
        <foreach item="bargainId" collection="array" open="(" separator="," close=")">
            #{bargainId}
        </foreach>
    </delete>
    
</mapper>