<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdCustomerMapper">
    
    <resultMap type="AdCustomer" id="AdCustomerResult">
        <id     property="customerId"    column="customer_id"    />
        <result property="customerName"  column="customer_name"  />
        <result property="contactPerson" column="contact_person" />
        <result property="phone"         column="phone"          />
        <result property="mobile"        column="mobile"         />
        <result property="email"         column="email"          />
        <result property="address"       column="address"        />
        <result property="areaId"        column="area_id"        />
        <result property="companyName"   column="company_name"   />
        <result property="companyType"   column="company_type"   />
        <result property="taxId"         column="tax_id"         />
        <result property="bankName"      column="bank_name"      />
        <result property="bankAccount"   column="bank_account"   />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>
    
    <sql id="selectCustomerVo">
        select customer_id, customer_name, contact_person, phone, mobile, email, address, area_id, company_name, company_type, tax_id, bank_name, bank_account, status, create_by, create_time, update_by, update_time, remark 
        from ad_customer
    </sql>
    
    <select id="selectCustomerList" parameterType="AdCustomer" resultMap="AdCustomerResult">
        <include refid="selectCustomerVo"/>
        <where>
            <if test="customerName != null and customerName != ''">
                AND customer_name like concat('%', #{customerName}, '%')
            </if>
            <if test="contactPerson != null and contactPerson != ''">
                AND contact_person like concat('%', #{contactPerson}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone = #{phone}
            </if>
            <if test="areaId != null">
                AND area_id = #{areaId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>
    
    <select id="selectCustomerById" parameterType="Long" resultMap="AdCustomerResult">
        <include refid="selectCustomerVo"/>
        where customer_id = #{customerId}
    </select>
    
    <insert id="insertCustomer" parameterType="AdCustomer" useGeneratedKeys="true" keyProperty="customerId">
        insert into ad_customer (
            <if test="customerName != null and customerName != ''">customer_name,</if>
            <if test="contactPerson != null">contact_person,</if>
            <if test="phone != null">phone,</if>
            <if test="mobile != null">mobile,</if>
            <if test="email != null">email,</if>
            <if test="address != null">address,</if>
            <if test="areaId != null">area_id,</if>
            <if test="companyName != null">company_name,</if>
            <if test="companyType != null">company_type,</if>
            <if test="taxId != null">tax_id,</if>
            <if test="bankName != null">bank_name,</if>
            <if test="bankAccount != null">bank_account,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        )values(
            <if test="customerName != null and customerName != ''">#{customerName},</if>
            <if test="contactPerson != null">#{contactPerson},</if>
            <if test="phone != null">#{phone},</if>
            <if test="mobile != null">#{mobile},</if>
            <if test="email != null">#{email},</if>
            <if test="address != null">#{address},</if>
            <if test="areaId != null">#{areaId},</if>
            <if test="companyName != null">#{companyName},</if>
            <if test="companyType != null">#{companyType},</if>
            <if test="taxId != null">#{taxId},</if>
            <if test="bankName != null">#{bankName},</if>
            <if test="bankAccount != null">#{bankAccount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateCustomer" parameterType="AdCustomer">
        update ad_customer 
        <set>
            <if test="customerName != null and customerName != ''">customer_name = #{customerName},</if>
            <if test="contactPerson != null">contact_person = #{contactPerson},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="mobile != null">mobile = #{mobile},</if>
            <if test="email != null">email = #{email},</if>
            <if test="address != null">address = #{address},</if>
            <if test="areaId != null">area_id = #{areaId},</if>
            <if test="companyName != null">company_name = #{companyName},</if>
            <if test="companyType != null">company_type = #{companyType},</if>
            <if test="taxId != null">tax_id = #{taxId},</if>
            <if test="bankName != null">bank_name = #{bankName},</if>
            <if test="bankAccount != null">bank_account = #{bankAccount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where customer_id = #{customerId}
    </update>
    
    <delete id="deleteCustomerById" parameterType="Long">
        delete from ad_customer where customer_id = #{customerId}
    </delete>
    
    <delete id="deleteCustomerByIds" parameterType="Long">
        delete from ad_customer where customer_id in 
        <foreach item="customerId" collection="array" open="(" separator="," close=")">
            #{customerId}
        </foreach>
    </delete>
    
</mapper>