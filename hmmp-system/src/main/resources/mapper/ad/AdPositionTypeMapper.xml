<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdPositionTypeMapper">
    
    <resultMap type="AdPositionType" id="AdPositionTypeResult">
        <id     property="typeId"       column="type_id"       />
        <result property="typeName"     column="type_name"     />
        <result property="typeCode"     column="type_code"     />
        <result property="description"  column="description"   />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
    </resultMap>
    
    <sql id="selectPositionTypeVo">
        select type_id, type_name, type_code, description, status, create_by, create_time, update_by, update_time 
        from ad_position_type
    </sql>
    
    <select id="selectPositionTypeList" parameterType="AdPositionType" resultMap="AdPositionTypeResult">
        <include refid="selectPositionTypeVo"/>
        <where>
            <if test="typeName != null and typeName != ''">
                AND type_name like concat('%', #{typeName}, '%')
            </if>
            <if test="typeCode != null and typeCode != ''">
                AND type_code = #{typeCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>
    
    <select id="selectPositionTypeById" parameterType="Long" resultMap="AdPositionTypeResult">
        <include refid="selectPositionTypeVo"/>
        where type_id = #{typeId}
    </select>
    
    <insert id="insertPositionType" parameterType="AdPositionType" useGeneratedKeys="true" keyProperty="typeId">
        insert into ad_position_type (
            <if test="typeName != null and typeName != ''">type_name,</if>
            <if test="typeCode != null">type_code,</if>
            <if test="description != null">description,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="typeName != null and typeName != ''">#{typeName},</if>
            <if test="typeCode != null">#{typeCode},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updatePositionType" parameterType="AdPositionType">
        update ad_position_type 
        <set>
            <if test="typeName != null and typeName != ''">type_name = #{typeName},</if>
            <if test="typeCode != null">type_code = #{typeCode},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where type_id = #{typeId}
    </update>
    
    <delete id="deletePositionTypeById" parameterType="Long">
        delete from ad_position_type where type_id = #{typeId}
    </delete>
    
    <delete id="deletePositionTypeByIds" parameterType="Long">
        delete from ad_position_type where type_id in 
        <foreach item="typeId" collection="array" open="(" separator="," close=")">
            #{typeId}
        </foreach>
    </delete>
    
</mapper>