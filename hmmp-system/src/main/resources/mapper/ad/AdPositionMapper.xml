<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdPositionMapper">
    
    <resultMap type="AdPosition" id="AdPositionResult">
        <id     property="positionId"    column="position_id"    />
        <result property="positionName"  column="position_name"  />
        <result property="typeId"        column="type_id"        />
        <result property="typeName"      column="type_name"      />
        <result property="width"         column="width"          />
        <result property="height"        column="height"         />
        <result property="positionCode"  column="position_code"  />
        <result property="pageLocation"  column="page_location"  />
        <result property="description"   column="description"    />
        <result property="status"        column="status"         />
        <result property="sortOrder"     column="sort_order"     />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
    </resultMap>
    
    <sql id="selectPositionVo">
        select position_id, position_name, type_id, type_name, width, height, position_code, page_location, description, status, sort_order, create_by, create_time, update_by, update_time 
        from ad_position
    </sql>
    
    <select id="selectPositionList" parameterType="AdPosition" resultMap="AdPositionResult">
        <include refid="selectPositionVo"/>
        <where>
            <if test="positionName != null and positionName != ''">
                AND position_name like concat('%', #{positionName}, '%')
            </if>
            <if test="typeId != null">
                AND type_id = #{typeId}
            </if>
            <if test="positionCode != null and positionCode != ''">
                AND position_code = #{positionCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort_order
    </select>
    
    <select id="selectPositionById" parameterType="Long" resultMap="AdPositionResult">
        <include refid="selectPositionVo"/>
        where position_id = #{positionId}
    </select>
    
    <insert id="insertPosition" parameterType="AdPosition" useGeneratedKeys="true" keyProperty="positionId">
        insert into ad_position (
            <if test="positionName != null and positionName != ''">position_name,</if>
            <if test="typeId != null">type_id,</if>
            <if test="typeName != null">type_name,</if>
            <if test="width != null">width,</if>
            <if test="height != null">height,</if>
            <if test="positionCode != null">position_code,</if>
            <if test="pageLocation != null">page_location,</if>
            <if test="description != null">description,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="positionName != null and positionName != ''">#{positionName},</if>
            <if test="typeId != null">#{typeId},</if>
            <if test="typeName != null">#{typeName},</if>
            <if test="width != null">#{width},</if>
            <if test="height != null">#{height},</if>
            <if test="positionCode != null">#{positionCode},</if>
            <if test="pageLocation != null">#{pageLocation},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updatePosition" parameterType="AdPosition">
        update ad_position 
        <set>
            <if test="positionName != null and positionName != ''">position_name = #{positionName},</if>
            <if test="typeId != null">type_id = #{typeId},</if>
            <if test="typeName != null">type_name = #{typeName},</if>
            <if test="width != null">width = #{width},</if>
            <if test="height != null">height = #{height},</if>
            <if test="positionCode != null">position_code = #{positionCode},</if>
            <if test="pageLocation != null">page_location = #{pageLocation},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where position_id = #{positionId}
    </update>
    
    <delete id="deletePositionById" parameterType="Long">
        delete from ad_position where position_id = #{positionId}
    </delete>
    
    <delete id="deletePositionByIds" parameterType="Long">
        delete from ad_position where position_id in 
        <foreach item="positionId" collection="array" open="(" separator="," close=")">
            #{positionId}
        </foreach>
    </delete>
    
</mapper>