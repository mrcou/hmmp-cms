<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdAreaMapper">
    
    <resultMap type="AdArea" id="AdAreaResult">
        <id     property="areaId"       column="area_id"       />
        <result property="areaName"     column="area_name"     />
        <result property="parentId"     column="parent_id"     />
        <result property="areaCode"     column="area_code"     />
        <result property="orderNum"     column="order_num"     />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
    </resultMap>
    
    <sql id="selectAreaVo">
        select area_id, area_name, parent_id, area_code, order_num, status, create_by, create_time, update_by, update_time 
        from ad_area
    </sql>
    
    <select id="selectAreaList" parameterType="AdArea" resultMap="AdAreaResult">
        <include refid="selectAreaVo"/>
        <where>
            <if test="areaName != null and areaName != ''">
                AND area_name like concat('%', #{areaName}, '%')
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by order_num
    </select>
    
    <select id="selectAreaById" parameterType="Long" resultMap="AdAreaResult">
        <include refid="selectAreaVo"/>
        where area_id = #{areaId}
    </select>
    
    <insert id="insertArea" parameterType="AdArea" useGeneratedKeys="true" keyProperty="areaId">
        insert into ad_area (
            <if test="areaName != null and areaName != ''">area_name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="areaCode != null">area_code,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="areaName != null and areaName != ''">#{areaName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="areaCode != null">#{areaCode},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateArea" parameterType="AdArea">
        update ad_area 
        <set>
            <if test="areaName != null and areaName != ''">area_name = #{areaName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="areaCode != null">area_code = #{areaCode},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where area_id = #{areaId}
    </update>
    
    <delete id="deleteAreaById" parameterType="Long">
        delete from ad_area where area_id = #{areaId}
    </delete>
    
    <delete id="deleteAreaByIds" parameterType="Long">
        delete from ad_area where area_id in 
        <foreach item="areaId" collection="array" open="(" separator="," close=")">
            #{areaId}
        </foreach>
    </delete>
    
</mapper>