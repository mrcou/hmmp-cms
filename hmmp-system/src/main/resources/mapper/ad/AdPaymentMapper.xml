<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdPaymentMapper">
    
    <resultMap type="AdPayment" id="AdPaymentResult">
        <id     property="paymentId"      column="payment_id"       />
        <result property="bargainId"      column="bargain_id"       />
        <result property="adId"           column="ad_id"            />
        <result property="paymentNo"      column="payment_no"       />
        <result property="paymentAmount"  column="payment_amount"   />
        <result property="paymentMethod"  column="payment_method"   />
        <result property="paymentStatus"  column="payment_status"   />
        <result property="paymentTime"    column="payment_time"     />
        <result property="receiptFile"    column="receipt_file"     />
        <result property="remark"         column="remark"           />
        <result property="createBy"       column="create_by"        />
        <result property="createTime"     column="create_time"      />
        <result property="updateBy"       column="update_by"        />
        <result property="updateTime"     column="update_time"      />
    </resultMap>
    
    <sql id="selectPaymentVo">
        select payment_id, bargain_id, ad_id, payment_no, payment_amount, payment_method, payment_status, payment_time, receipt_file, remark, create_by, create_time, update_by, update_time 
        from ad_payment
    </sql>
    
    <select id="selectPaymentList" parameterType="AdPayment" resultMap="AdPaymentResult">
        <include refid="selectPaymentVo"/>
        <where>
            <if test="paymentNo != null and paymentNo != ''">
                AND payment_no like concat('%', #{paymentNo}, '%')
            </if>
            <if test="bargainId != null">
                AND bargain_id = #{bargainId}
            </if>
            <if test="adId != null">
                AND ad_id = #{adId}
            </if>
            <if test="paymentStatus != null and paymentStatus != ''">
                AND payment_status = #{paymentStatus}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectPaymentById" parameterType="Long" resultMap="AdPaymentResult">
        <include refid="selectPaymentVo"/>
        where payment_id = #{paymentId}
    </select>
    
    <insert id="insertPayment" parameterType="AdPayment" useGeneratedKeys="true" keyProperty="paymentId">
        insert into ad_payment (
            <if test="bargainId != null">bargain_id,</if>
            <if test="adId != null">ad_id,</if>
            <if test="paymentNo != null and paymentNo != ''">payment_no,</if>
            <if test="paymentAmount != null">payment_amount,</if>
            <if test="paymentMethod != null">payment_method,</if>
            <if test="paymentStatus != null and paymentStatus != ''">payment_status,</if>
            <if test="paymentTime != null">payment_time,</if>
            <if test="receiptFile != null">receipt_file,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="bargainId != null">#{bargainId},</if>
            <if test="adId != null">#{adId},</if>
            <if test="paymentNo != null and paymentNo != ''">#{paymentNo},</if>
            <if test="paymentAmount != null">#{paymentAmount},</if>
            <if test="paymentMethod != null">#{paymentMethod},</if>
            <if test="paymentStatus != null and paymentStatus != ''">#{paymentStatus},</if>
            <if test="paymentTime != null">#{paymentTime},</if>
            <if test="receiptFile != null">#{receiptFile},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updatePayment" parameterType="AdPayment">
        update ad_payment 
        <set>
            <if test="bargainId != null">bargain_id = #{bargainId},</if>
            <if test="adId != null">ad_id = #{adId},</if>
            <if test="paymentNo != null and paymentNo != ''">payment_no = #{paymentNo},</if>
            <if test="paymentAmount != null">payment_amount = #{paymentAmount},</if>
            <if test="paymentMethod != null">payment_method = #{paymentMethod},</if>
            <if test="paymentStatus != null and paymentStatus != ''">payment_status = #{paymentStatus},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="receiptFile != null">receipt_file = #{receiptFile},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where payment_id = #{paymentId}
    </update>
    
    <delete id="deletePaymentById" parameterType="Long">
        delete from ad_payment where payment_id = #{paymentId}
    </delete>
    
    <delete id="deletePaymentByIds" parameterType="Long">
        delete from ad_payment where payment_id in 
        <foreach item="paymentId" collection="array" open="(" separator="," close=")">
            #{paymentId}
        </foreach>
    </delete>
    
</mapper>