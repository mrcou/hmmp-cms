<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.AdInvoiceMapper">
    
    <resultMap type="AdInvoice" id="AdInvoiceResult">
        <id     property="invoiceId"     column="invoice_id"      />
        <result property="bargainId"     column="bargain_id"      />
        <result property="invoiceNo"     column="invoice_no"      />
        <result property="invoiceType"   column="invoice_type"    />
        <result property="amount"        column="amount"          />
        <result property="taxAmount"     column="tax_amount"      />
        <result property="totalAmount"   column="total_amount"    />
        <result property="title"         column="title"           />
        <result property="taxId"         column="tax_id"          />
        <result property="applyStatus"   column="apply_status"    />
        <result property="auditTime"     column="audit_time"      />
        <result property="auditBy"       column="audit_by"        />
        <result property="makeStatus"    column="make_status"     />
        <result property="makeTime"      column="make_time"       />
        <result property="createBy"      column="create_by"       />
        <result property="createTime"    column="create_time"     />
        <result property="updateBy"      column="update_by"       />
        <result property="updateTime"    column="update_time"     />
    </resultMap>
    
    <sql id="selectInvoiceVo">
        select invoice_id, bargain_id, invoice_no, invoice_type, amount, tax_amount, total_amount, title, tax_id, apply_status, audit_time, audit_by, make_status, make_time, create_by, create_time, update_by, update_time 
        from ad_invoice
    </sql>
    
    <select id="selectInvoiceList" parameterType="AdInvoice" resultMap="AdInvoiceResult">
        <include refid="selectInvoiceVo"/>
        <where>
            <if test="invoiceNo != null and invoiceNo != ''">
                AND invoice_no like concat('%', #{invoiceNo}, '%')
            </if>
            <if test="bargainId != null">
                AND bargain_id = #{bargainId}
            </if>
            <if test="invoiceType != null and invoiceType != ''">
                AND invoice_type = #{invoiceType}
            </if>
            <if test="applyStatus != null and applyStatus != ''">
                AND apply_status = #{applyStatus}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectInvoiceById" parameterType="Long" resultMap="AdInvoiceResult">
        <include refid="selectInvoiceVo"/>
        where invoice_id = #{invoiceId}
    </select>
    
    <insert id="insertInvoice" parameterType="AdInvoice" useGeneratedKeys="true" keyProperty="invoiceId">
        insert into ad_invoice (
            <if test="bargainId != null">bargain_id,</if>
            <if test="invoiceNo != null">invoice_no,</if>
            <if test="invoiceType != null and invoiceType != ''">invoice_type,</if>
            <if test="amount != null">amount,</if>
            <if test="taxAmount != null">tax_amount,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="title != null">title,</if>
            <if test="taxId != null">tax_id,</if>
            <if test="applyStatus != null and applyStatus != ''">apply_status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="bargainId != null">#{bargainId},</if>
            <if test="invoiceNo != null">#{invoiceNo},</if>
            <if test="invoiceType != null and invoiceType != ''">#{invoiceType},</if>
            <if test="amount != null">#{amount},</if>
            <if test="taxAmount != null">#{taxAmount},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="title != null">#{title},</if>
            <if test="taxId != null">#{taxId},</if>
            <if test="applyStatus != null and applyStatus != ''">#{applyStatus},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateInvoice" parameterType="AdInvoice">
        update ad_invoice 
        <set>
            <if test="bargainId != null">bargain_id = #{bargainId},</if>
            <if test="invoiceNo != null">invoice_no = #{invoiceNo},</if>
            <if test="invoiceType != null and invoiceType != ''">invoice_type = #{invoiceType},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="taxAmount != null">tax_amount = #{taxAmount},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="title != null">title = #{title},</if>
            <if test="taxId != null">tax_id = #{taxId},</if>
            <if test="applyStatus != null and applyStatus != ''">apply_status = #{applyStatus},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="makeStatus != null and makeStatus != ''">make_status = #{makeStatus},</if>
            <if test="makeTime != null">make_time = #{makeTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where invoice_id = #{invoiceId}
    </update>
    
    <delete id="deleteInvoiceById" parameterType="Long">
        delete from ad_invoice where invoice_id = #{invoiceId}
    </delete>
    
    <delete id="deleteInvoiceByIds" parameterType="Long">
        delete from ad_invoice where invoice_id in 
        <foreach item="invoiceId" collection="array" open="(" separator="," close=")">
            #{invoiceId}
        </foreach>
    </delete>
    
</mapper>