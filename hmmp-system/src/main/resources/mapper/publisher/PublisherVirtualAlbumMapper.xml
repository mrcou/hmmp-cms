<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherVirtualAlbumMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" id="PublisherVirtualAlbumResult">
        <id     property="albumId"       column="album_id"         />
        <result property="albumName"     column="album_name"       />
        <result property="albumCode"     column="album_code"       />
        <result property="coverImage"    column="cover_image"      />
        <result property="description"   column="description"      />
        <result property="status"        column="status"           />
        <result property="createBy"      column="create_by"        />
        <result property="createTime"    column="create_time"      />
        <result property="updateBy"      column="update_by"        />
        <result property="updateTime"    column="update_time"      />
        <result property="remark"        column="remark"           />
    </resultMap>

    <sql id="selectPublisherVirtualAlbumVo">
        select album_id, album_name, album_code, cover_image, description, status,
               create_by, create_time, update_by, update_time, remark
        from publisher_virtual_album
    </sql>

    <select id="selectAlbumList" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" resultMap="PublisherVirtualAlbumResult">
        <include refid="selectPublisherVirtualAlbumVo"/>
        <where>
            <if test="albumName != null and albumName != ''">AND album_name like concat('%', #{albumName}, '%')</if>
            <if test="albumCode != null and albumCode != ''">AND album_code = #{albumCode}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAlbumById" parameterType="Long" resultMap="PublisherVirtualAlbumResult">
        <include refid="selectPublisherVirtualAlbumVo"/>
        where album_id = #{albumId}
    </select>

    <insert id="insertAlbum" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" useGeneratedKeys="true" keyProperty="albumId">
        insert into publisher_virtual_album (
            album_name, album_code, cover_image, description, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{albumName}, #{albumCode}, #{coverImage}, #{description}, #{status},
            #{createBy}, sysdate(), #{updateBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updateAlbum" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum">
        update publisher_virtual_album
        <set>
            <if test="albumName != null">album_name = #{albumName},</if>
            <if test="albumCode != null">album_code = #{albumCode},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where album_id = #{albumId}
    </update>

    <delete id="deleteAlbumById" parameterType="Long">
        delete from publisher_virtual_album where album_id = #{albumId}
    </delete>

    <delete id="deleteAlbumByIds" parameterType="Long">
        delete from publisher_virtual_album where album_id in
        <foreach collection="array" item="albumId" open="(" separator="," close=")">
            #{albumId}
        </foreach>
    </delete>

</mapper>