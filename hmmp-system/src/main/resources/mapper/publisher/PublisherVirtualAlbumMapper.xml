<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherVirtualAlbumMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" id="PublisherVirtualAlbumResult">
        <id     property="albumId"       column="album_id"         />
        <result property="journalCode"   column="journal_code"     />
        <result property="nameCn"        column="name_cn"          />
        <result property="nameEn"        column="name_en"          />
        <result property="finishDate"    column="finish_date"      />
        <result property="orderNum"      column="order_num"        />
        <result property="albumType"     column="album_type"       />
        <result property="meetingId"     column="meeting_id"       />
        <result property="coverImage"    column="cover_image"      />
        <result property="description"   column="description"      />
        <result property="status"        column="status"           />
        <result property="createBy"      column="create_by"        />
        <result property="createTime"    column="create_time"      />
        <result property="updateBy"      column="update_by"        />
        <result property="updateTime"    column="update_time"      />
        <result property="remark"        column="remark"           />
    </resultMap>

    <sql id="selectPublisherVirtualAlbumVo">
        select album_id, journal_code, name_cn, name_en, finish_date, order_num, album_type,
               meeting_id, cover_image, description, status,
               create_by, create_time, update_by, update_time, remark
        from publisher_virtual_album
    </sql>

    <select id="selectAlbumList" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" resultMap="PublisherVirtualAlbumResult">
        <include refid="selectPublisherVirtualAlbumVo"/>
        <where>
            <if test="albumId != null">AND album_id = #{albumId}</if>
            <if test="journalCode != null and journalCode != ''">AND journal_code = #{journalCode}</if>
            <if test="nameCn != null and nameCn != ''">AND name_cn like concat('%', #{nameCn}, '%')</if>
            <if test="nameEn != null and nameEn != ''">AND name_en like concat('%', #{nameEn}, '%')</if>
            <if test="albumType != null and albumType != ''">AND album_type = #{albumType}</if>
            <if test="meetingId != null">AND meeting_id = #{meetingId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
            <if test="createBy != null and createBy != ''">AND create_by like concat('%', #{createBy}, '%')</if>
        </where>
        order by order_num asc, album_id desc
    </select>

    <select id="selectAlbumById" parameterType="Long" resultMap="PublisherVirtualAlbumResult">
        <include refid="selectPublisherVirtualAlbumVo"/>
        where album_id = #{albumId}
    </select>

    <insert id="insertAlbum" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum" useGeneratedKeys="true" keyProperty="albumId">
        insert into publisher_virtual_album (
            journal_code, name_cn, name_en, finish_date, order_num, album_type, meeting_id,
            cover_image, description, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{journalCode}, #{nameCn}, #{nameEn}, #{finishDate}, #{orderNum}, #{albumType}, #{meetingId},
            #{coverImage}, #{description}, #{status},
            #{createBy}, sysdate(), #{updateBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updateAlbum" parameterType="com.hmmp.system.domain.publisher.PublisherVirtualAlbum">
        update publisher_virtual_album
        <set>
            <if test="journalCode != null">journal_code = #{journalCode},</if>
            <if test="nameCn != null">name_cn = #{nameCn},</if>
            <if test="nameEn != null">name_en = #{nameEn},</if>
            <if test="finishDate != null">finish_date = #{finishDate},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="albumType != null">album_type = #{albumType},</if>
            <if test="meetingId != null">meeting_id = #{meetingId},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            update_by = #{updateBy},
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where album_id = #{albumId}
    </update>

    <delete id="deleteAlbumById" parameterType="Long">
        delete from publisher_virtual_album where album_id = #{albumId}
    </delete>

    <delete id="deleteAlbumByIds" parameterType="Long">
        delete from publisher_virtual_album where album_id in
        <foreach collection="array" item="albumId" open="(" separator="," close=")">
            #{albumId}
        </foreach>
    </delete>

</mapper>
