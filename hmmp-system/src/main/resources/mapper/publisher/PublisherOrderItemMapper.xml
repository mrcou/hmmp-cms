<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherOrderItemMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherOrderItem" id="PublisherOrderItemResult">
        <id     property="itemId"       column="item_id"          />
        <result property="orderId"      column="order_id"         />
        <result property="issueId"      column="issue_id"         />
        <result property="year"         column="year"             />
        <result property="period"       column="period"           />
        <result property="productName"  column="product_name"     />
        <result property="qty"          column="qty"              />
        <result property="unitPrice"    column="unit_price"       />
        <result property="amount"       column="amount"           />
        <result property="status"       column="status"           />
        <result property="createTime"   column="create_time"      />
    </resultMap>

    <sql id="selectPublisherOrderItemVo">
        select item_id, order_id, issue_id, year, period, product_name, qty, unit_price, amount, status, create_time
        from publisher_order_item
    </sql>

    <select id="selectOrderItemList" parameterType="com.hmmp.system.domain.publisher.PublisherOrderItem" resultMap="PublisherOrderItemResult">
        <include refid="selectPublisherOrderItemVo"/>
        <where>
            <if test="orderId != null">AND order_id = #{orderId}</if>
            <if test="issueId != null">AND issue_id = #{issueId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectOrderItemById" parameterType="Long" resultMap="PublisherOrderItemResult">
        <include refid="selectPublisherOrderItemVo"/>
        where item_id = #{itemId}
    </select>

    <select id="selectOrderItemByOrderId" parameterType="Long" resultMap="PublisherOrderItemResult">
        <include refid="selectPublisherOrderItemVo"/>
        where order_id = #{orderId}
    </select>

    <insert id="insertOrderItem" parameterType="com.hmmp.system.domain.publisher.PublisherOrderItem" useGeneratedKeys="true" keyProperty="itemId">
        insert into publisher_order_item (
            order_id, issue_id, year, period, product_name, qty, unit_price, amount, status, create_time
        ) values (
            #{orderId}, #{issueId}, #{year}, #{period}, #{productName}, #{qty}, #{unitPrice}, #{amount}, #{status}, sysdate()
        )
    </insert>

    <update id="updateOrderItem" parameterType="com.hmmp.system.domain.publisher.PublisherOrderItem">
        update publisher_order_item
        <set>
            <if test="issueId != null">issue_id = #{issueId},</if>
            <if test="year != null">year = #{year},</if>
            <if test="period != null">period = #{period},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="qty != null">qty = #{qty},</if>
            <if test="unitPrice != null">unit_price = #{unitPrice},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where item_id = #{itemId}
    </update>

    <delete id="deleteOrderItemById" parameterType="Long">
        delete from publisher_order_item where item_id = #{itemId}
    </delete>

    <delete id="deleteOrderItemByIds" parameterType="Long">
        delete from publisher_order_item where item_id in
        <foreach collection="array" item="itemId" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <delete id="deleteByOrderId" parameterType="Long">
        delete from publisher_order_item where order_id = #{orderId}
    </delete>

</mapper>