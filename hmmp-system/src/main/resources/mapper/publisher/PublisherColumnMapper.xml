<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherColumnMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherColumn" id="PublisherColumnResult">
        <id     property="columnId"      column="column_id"        />
        <result property="columnName"    column="column_name"      />
        <result property="parentId"      column="parent_id"        />
        <result property="orderNum"      column="order_num"        />
        <result property="columnCode"    column="column_code"      />
        <result property="columnType"    column="column_type"      />
        <result property="status"        column="status"           />
        <result property="description"   column="description"      />
        <result property="createBy"      column="create_by"        />
        <result property="createTime"    column="create_time"      />
        <result property="updateBy"      column="update_by"        />
        <result property="updateTime"    column="update_time"      />
    </resultMap>

    <sql id="selectPublisherColumnVo">
        select column_id, column_name, parent_id, order_num, column_code, column_type, status,
               description, create_by, create_time, update_by, update_time
        from publisher_column
    </sql>

    <select id="selectColumnList" parameterType="com.hmmp.system.domain.publisher.PublisherColumn" resultMap="PublisherColumnResult">
        <include refid="selectPublisherColumnVo"/>
        <where>
            <if test="columnName != null and columnName != ''">AND column_name like concat('%', #{columnName}, '%')</if>
            <if test="parentId != null">AND parent_id = #{parentId}</if>
            <if test="columnType != null and columnType != ''">AND column_type = #{columnType}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by order_num asc
    </select>

    <select id="selectColumnById" parameterType="Long" resultMap="PublisherColumnResult">
        <include refid="selectPublisherColumnVo"/>
        where column_id = #{columnId}
    </select>

    <insert id="insertColumn" parameterType="com.hmmp.system.domain.publisher.PublisherColumn" useGeneratedKeys="true" keyProperty="columnId">
        insert into publisher_column (
            column_name, parent_id, order_num, column_code, column_type, status,
            description, create_by, create_time, update_by, update_time
        ) values (
            #{columnName}, #{parentId}, #{orderNum}, #{columnCode}, #{columnType}, #{status},
            #{description}, #{createBy}, sysdate(), #{updateBy}, sysdate()
        )
    </insert>

    <update id="updateColumn" parameterType="com.hmmp.system.domain.publisher.PublisherColumn">
        update publisher_column
        <set>
            <if test="columnName != null">column_name = #{columnName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="columnCode != null">column_code = #{columnCode},</if>
            <if test="columnType != null">column_type = #{columnType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            update_by = #{updateBy},
            update_time = sysdate()
        </set>
        where column_id = #{columnId}
    </update>

    <delete id="deleteColumnById" parameterType="Long">
        delete from publisher_column where column_id = #{columnId}
    </delete>

    <delete id="deleteColumnByIds" parameterType="Long">
        delete from publisher_column where column_id in
        <foreach collection="array" item="columnId" open="(" separator="," close=")">
            #{columnId}
        </foreach>
    </delete>

</mapper>