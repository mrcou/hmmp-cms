<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherReaderMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherReader" id="PublisherReaderResult">
        <id     property="readerId"       column="reader_id"         />
        <result property="userId"         column="user_id"           />
        <result property="realName"       column="real_name"         />
        <result property="nickName"       column="nick_name"         />
        <result property="gender"         column="gender"            />
        <result property="birthday"       column="birthday"          />
        <result property="email"          column="email"             />
        <result property="phone"          column="phone"             />
        <result property="mobile"         column="mobile"            />
        <result property="address"        column="address"           />
        <result property="zipCode"        column="zip_code"          />
        <result property="registerTime"   column="register_time"     />
        <result property="lastLoginTime"  column="last_login_time"   />
        <result property="status"         column="status"            />
        <result property="createBy"       column="create_by"         />
        <result property="createTime"     column="create_time"       />
        <result property="updateBy"       column="update_by"         />
        <result property="updateTime"     column="update_time"       />
    </resultMap>

    <sql id="selectPublisherReaderVo">
        select reader_id, user_id, real_name, nick_name, gender, birthday, email, phone, mobile,
               address, zip_code, register_time, last_login_time, status, create_by, create_time, update_by, update_time
        from publisher_reader
    </sql>

    <select id="selectReaderList" parameterType="com.hmmp.system.domain.publisher.PublisherReader" resultMap="PublisherReaderResult">
        <include refid="selectPublisherReaderVo"/>
        <where>
            <if test="realName != null and realName != ''">AND real_name like concat('%', #{realName}, '%')</if>
            <if test="nickName != null and nickName != ''">AND nick_name like concat('%', #{nickName}, '%')</if>
            <if test="email != null and email != ''">AND email like concat('%', #{email}, '%')</if>
            <if test="phone != null and phone != ''">AND phone = #{phone}</if>
            <if test="mobile != null and mobile != ''">AND mobile = #{mobile}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectReaderById" parameterType="Long" resultMap="PublisherReaderResult">
        <include refid="selectPublisherReaderVo"/>
        where reader_id = #{readerId}
    </select>

    <select id="selectReaderByUserId" parameterType="Long" resultMap="PublisherReaderResult">
        <include refid="selectPublisherReaderVo"/>
        where user_id = #{userId}
    </select>

    <insert id="insertReader" parameterType="com.hmmp.system.domain.publisher.PublisherReader" useGeneratedKeys="true" keyProperty="readerId">
        insert into publisher_reader (
            user_id, real_name, nick_name, gender, birthday, email, phone, mobile,
            address, zip_code, register_time, last_login_time, status, create_by, create_time, update_by, update_time
        ) values (
            #{userId}, #{realName}, #{nickName}, #{gender}, #{birthday}, #{email}, #{phone}, #{mobile},
            #{address}, #{zipCode}, #{registerTime}, #{lastLoginTime}, #{status}, #{createBy}, sysdate(), #{updateBy}, sysdate()
        )
    </insert>

    <update id="updateReader" parameterType="com.hmmp.system.domain.publisher.PublisherReader">
        update publisher_reader
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="mobile != null">mobile = #{mobile},</if>
            <if test="address != null">address = #{address},</if>
            <if test="zipCode != null">zip_code = #{zipCode},</if>
            <if test="registerTime != null">register_time = #{registerTime},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = sysdate()
        </set>
        where reader_id = #{readerId}
    </update>

    <update id="updateReaderStatus" parameterType="com.hmmp.system.domain.publisher.PublisherReader">
        update publisher_reader set status = #{status}, update_by = #{updateBy}, update_time = sysdate()
        where reader_id = #{readerId}
    </update>

    <delete id="deleteReaderById" parameterType="Long">
        delete from publisher_reader where reader_id = #{readerId}
    </delete>

    <delete id="deleteReaderByIds" parameterType="Long">
        delete from publisher_reader where reader_id in
        <foreach collection="array" item="readerId" open="(" separator="," close=")">
            #{readerId}
        </foreach>
    </delete>

</mapper>