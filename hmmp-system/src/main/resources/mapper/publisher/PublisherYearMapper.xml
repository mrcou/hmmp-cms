<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherYearMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherYear" id="PublisherYearResult">
        <id     property="yearId"        column="year_id"          />
        <result property="journalCode"   column="journal_code"     />
        <result property="year"          column="year"             />
        <result property="volume"        column="volume"           />
        <result property="nameCn"        column="name_cn"          />
        <result property="nameEn"        column="name_en"          />
        <result property="catalogFile"   column="catalog_file"     />
        <result property="isFree"        column="is_free"          />
        <result property="meetingId"     column="meeting_id"       />
        <result property="status"        column="status"           />
        <result property="createBy"      column="create_by"        />
        <result property="createTime"    column="create_time"      />
        <result property="updateBy"      column="update_by"        />
        <result property="updateTime"    column="update_time"      />
        <result property="remark"        column="remark"           />
    </resultMap>

    <sql id="selectPublisherYearVo">
        select year_id, journal_code, year, volume, name_cn, name_en, catalog_file, is_free,
               meeting_id, status, create_by, create_time, update_by, update_time, remark
        from publisher_year
    </sql>

    <select id="selectYearList" parameterType="com.hmmp.system.domain.publisher.PublisherYear" resultMap="PublisherYearResult">
        <include refid="selectPublisherYearVo"/>
        <where>
            <if test="journalCode != null and journalCode != ''">AND journal_code = #{journalCode}</if>
            <if test="year != null">AND year = #{year}</if>
            <if test="volume != null">AND volume = #{volume}</if>
            <if test="nameCn != null and nameCn != ''">AND name_cn like concat('%', #{nameCn}, '%')</if>
            <if test="nameEn != null and nameEn != ''">AND name_en like concat('%', #{nameEn}, '%')</if>
            <if test="isFree != null and isFree != ''">AND is_free = #{isFree}</if>
            <if test="meetingId != null">AND meeting_id = #{meetingId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by year desc, year_id desc
    </select>

    <select id="selectYearById" parameterType="Long" resultMap="PublisherYearResult">
        <include refid="selectPublisherYearVo"/>
        where year_id = #{yearId}
    </select>

    <select id="checkYearUnique" parameterType="com.hmmp.system.domain.publisher.PublisherYear" resultMap="PublisherYearResult">
        <include refid="selectPublisherYearVo"/>
        where year = #{year}
          and ifnull(journal_code, '') = ifnull(#{journalCode}, '')
        limit 1
    </select>

    <insert id="insertYear" parameterType="com.hmmp.system.domain.publisher.PublisherYear" useGeneratedKeys="true" keyProperty="yearId">
        insert into publisher_year (
            journal_code, year, volume, name_cn, name_en, catalog_file, is_free, meeting_id,
            status, create_by, create_time, update_by, update_time, remark
        ) values (
            #{journalCode}, #{year}, #{volume}, #{nameCn}, #{nameEn}, #{catalogFile}, #{isFree}, #{meetingId},
            #{status}, #{createBy}, sysdate(), #{updateBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updateYear" parameterType="com.hmmp.system.domain.publisher.PublisherYear">
        update publisher_year
        <set>
            <if test="journalCode != null">journal_code = #{journalCode},</if>
            <if test="year != null">year = #{year},</if>
            <if test="volume != null">volume = #{volume},</if>
            <if test="nameCn != null">name_cn = #{nameCn},</if>
            <if test="nameEn != null">name_en = #{nameEn},</if>
            <if test="catalogFile != null">catalog_file = #{catalogFile},</if>
            <if test="isFree != null and isFree != ''">is_free = #{isFree},</if>
            <if test="meetingId != null">meeting_id = #{meetingId},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            update_by = #{updateBy},
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where year_id = #{yearId}
    </update>

    <delete id="deleteYearById" parameterType="Long">
        delete from publisher_year where year_id = #{yearId}
    </delete>

    <delete id="deleteYearByIds" parameterType="Long">
        delete from publisher_year where year_id in
        <foreach collection="array" item="yearId" open="(" separator="," close=")">
            #{yearId}
        </foreach>
    </delete>

</mapper>
