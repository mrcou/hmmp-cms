<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.publisher.PublisherPriceMapper">

    <resultMap type="com.hmmp.system.domain.publisher.PublisherPrice" id="PublisherPriceResult">
        <id     property="priceId"        column="price_id"          />
        <result property="yearId"         column="year_id"           />
        <result property="year"           column="year"              />
        <result property="period"         column="period"            />
        <result property="priceType"      column="price_type"        />
        <result property="price"          column="price"             />
        <result property="currency"       column="currency"          />
        <result property="status"         column="status"            />
        <result property="validStartDate" column="valid_start_date"  />
        <result property="validEndDate"   column="valid_end_date"    />
        <result property="createBy"       column="create_by"         />
        <result property="createTime"     column="create_time"       />
        <result property="updateBy"       column="update_by"         />
        <result property="updateTime"     column="update_time"       />
    </resultMap>

    <sql id="selectPublisherPriceVo">
        select price_id, year_id, year, period, price_type, price, currency, status,
               valid_start_date, valid_end_date, create_by, create_time, update_by, update_time
        from publisher_price
    </sql>

    <select id="selectPriceList" parameterType="com.hmmp.system.domain.publisher.PublisherPrice" resultMap="PublisherPriceResult">
        <include refid="selectPublisherPriceVo"/>
        <where>
            <if test="yearId != null">AND year_id = #{yearId}</if>
            <if test="year != null">AND year = #{year}</if>
            <if test="period != null">AND period = #{period}</if>
            <if test="priceType != null and priceType != ''">AND price_type = #{priceType}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by year desc, period desc
    </select>

    <select id="selectPriceById" parameterType="Long" resultMap="PublisherPriceResult">
        <include refid="selectPublisherPriceVo"/>
        where price_id = #{priceId}
    </select>

    <insert id="insertPrice" parameterType="com.hmmp.system.domain.publisher.PublisherPrice" useGeneratedKeys="true" keyProperty="priceId">
        insert into publisher_price (
            year_id, year, period, price_type, price, currency, status,
            valid_start_date, valid_end_date, create_by, create_time, update_by, update_time
        ) values (
            #{yearId}, #{year}, #{period}, #{priceType}, #{price}, #{currency}, #{status},
            #{validStartDate}, #{validEndDate}, #{createBy}, sysdate(), #{updateBy}, sysdate()
        )
    </insert>

    <update id="updatePrice" parameterType="com.hmmp.system.domain.publisher.PublisherPrice">
        update publisher_price
        <set>
            <if test="yearId != null">year_id = #{yearId},</if>
            <if test="year != null">year = #{year},</if>
            <if test="period != null">period = #{period},</if>
            <if test="priceType != null">price_type = #{priceType},</if>
            <if test="price != null">price = #{price},</if>
            <if test="currency != null">currency = #{currency},</if>
            <if test="status != null">status = #{status},</if>
            <if test="validStartDate != null">valid_start_date = #{validStartDate},</if>
            <if test="validEndDate != null">valid_end_date = #{validEndDate},</if>
            update_by = #{updateBy},
            update_time = sysdate()
        </set>
        where price_id = #{priceId}
    </update>

    <delete id="deletePriceById" parameterType="Long">
        delete from publisher_price where price_id = #{priceId}
    </delete>

    <delete id="deletePriceByIds" parameterType="Long">
        delete from publisher_price where price_id in
        <foreach collection="array" item="priceId" open="(" separator="," close=")">
            #{priceId}
        </foreach>
    </delete>

</mapper>