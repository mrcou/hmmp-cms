<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.EditorGroupMapper">

    <resultMap type="EditorGroup" id="EditorGroupResult">
        <id     property="groupId"       column="group_id"        />
        <result property="groupName"     column="group_name"      />
        <result property="issueId"       column="issue_id"        />
        <result property="groupType"     column="group_type"      />
        <result property="status"        column="status"          />
        <result property="createBy"      column="create_by"       />
        <result property="createTime"    column="create_time"     />
        <result property="updateBy"      column="update_by"       />
        <result property="updateTime"    column="update_time"     />
        <result property="remark"        column="remark"          />
    </resultMap>

    <sql id="selectEditorGroupVo">
        select group_id, group_name, issue_id, group_type, status,
               create_by, create_time, update_by, update_time, remark
        from editor_group
    </sql>

    <select id="selectGroupList" parameterType="EditorGroup" resultMap="EditorGroupResult">
        <include refid="selectEditorGroupVo"/>
        <where>
            <if test="groupName != null and groupName != ''">AND group_name like concat('%', #{groupName}, '%')</if>
            <if test="issueId != null">AND issue_id = #{issueId}</if>
            <if test="groupType != null and groupType != ''">AND group_type = #{groupType}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectGroupById" parameterType="Long" resultMap="EditorGroupResult">
        <include refid="selectEditorGroupVo"/>
        where group_id = #{groupId}
    </select>

    <select id="selectGroupByIssueId" parameterType="Long" resultMap="EditorGroupResult">
        <include refid="selectEditorGroupVo"/>
        where issue_id = #{issueId}
    </select>

    <insert id="insertGroup" parameterType="EditorGroup" useGeneratedKeys="true" keyProperty="groupId">
        insert into editor_group (
            group_name, issue_id, group_type, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{groupName}, #{issueId}, #{groupType}, #{status},
            #{createBy}, sysdate(), #{updateBy}, sysdate(), #{remark}
        )
    </insert>

    <update id="updateGroup" parameterType="EditorGroup">
        update editor_group
        <set>
            <if test="groupName != null">group_name = #{groupName},</if>
            <if test="issueId != null">issue_id = #{issueId},</if>
            <if test="groupType != null">group_type = #{groupType},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where group_id = #{groupId}
    </update>

    <update id="updateGroupStatus" parameterType="EditorGroup">
        update editor_group set status = #{status}, update_by = #{updateBy}, update_time = sysdate()
        where group_id = #{groupId}
    </update>

    <delete id="deleteGroupById" parameterType="Long">
        delete from editor_group where group_id = #{groupId}
    </delete>

    <delete id="deleteGroupByIds" parameterType="Long">
        delete from editor_group where group_id in
        <foreach collection="array" item="groupId" open="(" separator="," close=")">
            #{groupId}
        </foreach>
    </delete>

</mapper>