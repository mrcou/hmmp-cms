<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.meeting.MeetingTravelBookedMapper">

    <resultMap type="MeetingTravelBooked" id="MeetingTravelBookedResult">
        <id     property="bookedId"     column="booked_id"     />
        <result property="wayId"        column="way_id"        />
        <result property="userId"       column="user_id"       />
        <result property="meetingId"    column="meeting_id"    />
        <result property="qty"          column="qty"           />
        <result property="totalAmount"  column="total_amount"  />
        <result property="status"       column="status"        />
        <result property="createTime"   column="create_time"   />
    </resultMap>

    <sql id="selectTravelBookedVo">
        select booked_id, way_id, user_id, meeting_id, qty, total_amount, status, create_time
        from meeting_travel_booked
    </sql>

    <select id="selectTravelBookedList" parameterType="MeetingTravelBooked" resultMap="MeetingTravelBookedResult">
        <include refid="selectTravelBookedVo"/>
        <where>
            <if test="meetingId != null">AND meeting_id = #{meetingId}</if>
            <if test="wayId != null">AND way_id = #{wayId}</if>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectTravelBookedById" parameterType="Long" resultMap="MeetingTravelBookedResult">
        <include refid="selectTravelBookedVo"/>
        where booked_id = #{bookedId}
    </select>

    <insert id="insertTravelBooked" parameterType="MeetingTravelBooked" useGeneratedKeys="true" keyProperty="bookedId">
        insert into meeting_travel_booked(
            <if test="wayId != null">way_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="meetingId != null">meeting_id,</if>
            <if test="qty != null">qty,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            create_time
        )values(
            <if test="wayId != null">#{wayId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="meetingId != null">#{meetingId},</if>
            <if test="qty != null">#{qty},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        )
    </insert>

    <update id="updateTravelBooked" parameterType="MeetingTravelBooked">
        update meeting_travel_booked
        <set>
            <if test="wayId != null">way_id = #{wayId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="meetingId != null">meeting_id = #{meetingId},</if>
            <if test="qty != null">qty = #{qty},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where booked_id = #{bookedId}
    </update>

    <delete id="deleteTravelBookedById" parameterType="Long">
        delete from meeting_travel_booked where booked_id = #{bookedId}
    </delete>

    <delete id="deleteTravelBookedByIds" parameterType="Long">
        delete from meeting_travel_booked where booked_id in
        <foreach collection="array" item="bookedId" open="(" separator="," close=")">
            #{bookedId}
        </foreach>
    </delete>

</mapper>