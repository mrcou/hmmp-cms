<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hmmp.system.mapper.meeting.MeetingUserMapper">

    <resultMap type="MeetingUser" id="MeetingUserResult">
        <id     property="userId"         column="user_id"          />
        <result property="meetingId"      column="meeting_id"       />
        <result property="groupId"        column="group_id"         />
        <result property="realName"       column="real_name"        />
        <result property="gender"         column="gender"           />
        <result property="affiliation"    column="affiliation"      />
        <result property="title"          column="title"            />
        <result property="email"          column="email"            />
        <result property="phone"          column="phone"            />
        <result property="mobile"         column="mobile"           />
        <result property="registerTime"   column="register_time"    />
        <result property="paymentStatus"  column="payment_status"   />
        <result property="paymentAmount"  column="payment_amount"   />
        <result property="status"         column="status"           />
        <result property="createTime"     column="create_time"      />
    </resultMap>

    <sql id="selectUserVo">
        select user_id, meeting_id, group_id, real_name, gender, affiliation, title,
               email, phone, mobile, register_time, payment_status, payment_amount, status, create_time
        from meeting_user
    </sql>

    <select id="selectUserList" parameterType="MeetingUser" resultMap="MeetingUserResult">
        <include refid="selectUserVo"/>
        <where>
            <if test="meetingId != null">AND meeting_id = #{meetingId}</if>
            <if test="groupId != null">AND group_id = #{groupId}</if>
            <if test="realName != null and realName != ''">AND real_name like concat('%', #{realName}, '%')</if>
            <if test="affiliation != null and affiliation != ''">AND affiliation like concat('%', #{affiliation}, '%')</if>
            <if test="email != null and email != ''">AND email = #{email}</if>
            <if test="phone != null and phone != ''">AND (phone = #{phone} or mobile = #{phone})</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
            <if test="paymentStatus != null and paymentStatus != ''">AND payment_status = #{paymentStatus}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectUserById" parameterType="Long" resultMap="MeetingUserResult">
        <include refid="selectUserVo"/>
        where user_id = #{userId}
    </select>

    <insert id="insertUser" parameterType="MeetingUser" useGeneratedKeys="true" keyProperty="userId">
        insert into meeting_user(
            <if test="meetingId != null">meeting_id,</if>
            <if test="groupId != null">group_id,</if>
            <if test="realName != null and realName != ''">real_name,</if>
            <if test="gender != null">gender,</if>
            <if test="affiliation != null">affiliation,</if>
            <if test="title != null">title,</if>
            <if test="email != null">email,</if>
            <if test="phone != null">phone,</if>
            <if test="mobile != null">mobile,</if>
            <if test="registerTime != null">register_time,</if>
            <if test="paymentStatus != null">payment_status,</if>
            <if test="paymentAmount != null">payment_amount,</if>
            <if test="status != null">status,</if>
            create_time
        )values(
            <if test="meetingId != null">#{meetingId},</if>
            <if test="groupId != null">#{groupId},</if>
            <if test="realName != null and realName != ''">#{realName},</if>
            <if test="gender != null">#{gender},</if>
            <if test="affiliation != null">#{affiliation},</if>
            <if test="title != null">#{title},</if>
            <if test="email != null">#{email},</if>
            <if test="phone != null">#{phone},</if>
            <if test="mobile != null">#{mobile},</if>
            <if test="registerTime != null">#{registerTime},</if>
            <if test="paymentStatus != null">#{paymentStatus},</if>
            <if test="paymentAmount != null">#{paymentAmount},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        )
    </insert>

    <update id="updateUser" parameterType="MeetingUser">
        update meeting_user
        <set>
            <if test="meetingId != null">meeting_id = #{meetingId},</if>
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="realName != null and realName != ''">real_name = #{realName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="affiliation != null">affiliation = #{affiliation},</if>
            <if test="title != null">title = #{title},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="mobile != null">mobile = #{mobile},</if>
            <if test="registerTime != null">register_time = #{registerTime},</if>
            <if test="paymentStatus != null">payment_status = #{paymentStatus},</if>
            <if test="paymentAmount != null">payment_amount = #{paymentAmount},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where user_id = #{userId}
    </update>

    <delete id="deleteUserById" parameterType="Long">
        delete from meeting_user where user_id = #{userId}
    </delete>

    <delete id="deleteUserByIds" parameterType="Long">
        delete from meeting_user where user_id in
        <foreach collection="array" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </delete>

</mapper>